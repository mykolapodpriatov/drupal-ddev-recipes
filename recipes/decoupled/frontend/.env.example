# Browser-visible Drupal URL.
NEXT_PUBLIC_DRUPAL_BASE_URL=https://api.drupal-decoupled.ddev.site

# Container-internal Drupal URL (faster, no TLS round-trip on SSR).
NEXT_INTERNAL_DRUPAL_URL=http://web

# next-drupal preview secret (must match Drupal's `next.next_site` config).
DRUPAL_PREVIEW_SECRET=changeme
DRUPAL_CLIENT_ID=
DRUPAL_CLIENT_SECRET=
