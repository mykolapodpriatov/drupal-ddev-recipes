# Browser-visible Drupal URL.
# CHANGE THIS: the value below assumes a DDEV project named `drupal-decoupled`.
# Set it to https://api.<your-project>.ddev.site (matches $DDEV_SITENAME), or
# to whatever hostname serves Drupal in your setup. The frontend will not reach
# Drupal until this points at the correct host.
NEXT_PUBLIC_DRUPAL_BASE_URL=https://api.drupal-decoupled.ddev.site

# Container-internal Drupal URL (faster, no TLS round-trip on SSR).
NEXT_INTERNAL_DRUPAL_URL=http://web

# next-drupal preview secret. This MUST match the secret configured on the
# Drupal side in the `next.next_site` config entity for the same environment.
# `changeme` is only a placeholder — replace it with a real shared secret.
DRUPAL_PREVIEW_SECRET=changeme
DRUPAL_CLIENT_ID=
DRUPAL_CLIENT_SECRET=
