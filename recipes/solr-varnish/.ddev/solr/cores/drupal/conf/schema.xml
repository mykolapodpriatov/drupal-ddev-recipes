<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal schema for a Drupal search_api_solr 4.x core.
  Real projects should export the schema from the search_api_solr UI
  ("Get config.zip") which generates the full set of dynamic fields,
  language-specific text analysers, and copy fields.

  This stub exists so the core can be created on first boot and is enough
  for the admin UI ping to succeed — replace before going to production.
-->
<schema name="drupal" version="1.6">

  <uniqueKey>id</uniqueKey>

  <field name="id" type="string" indexed="true" stored="true" required="true"/>
  <field name="index_id" type="string" indexed="true" stored="true"/>
  <field name="hash" type="string" indexed="true" stored="true"/>
  <field name="site" type="string" indexed="true" stored="true"/>
  <field name="_text_" type="text_en" indexed="true" stored="false" multiValued="true"/>
  <field name="_version_" type="plong" indexed="true" stored="true"/>
  <field name="_root_" type="string" indexed="true" stored="false" docValues="false"/>

  <dynamicField name="ss_*" type="string" indexed="true" stored="true"/>
  <dynamicField name="sm_*" type="string" indexed="true" stored="true" multiValued="true"/>
  <dynamicField name="is_*" type="pint" indexed="true" stored="true"/>
  <dynamicField name="im_*" type="pint" indexed="true" stored="true" multiValued="true"/>
  <dynamicField name="fs_*" type="pfloat" indexed="true" stored="true"/>
  <dynamicField name="bs_*" type="boolean" indexed="true" stored="true"/>
  <dynamicField name="ds_*" type="pdate" indexed="true" stored="true"/>
  <dynamicField name="tm_*" type="text_en" indexed="true" stored="true" multiValued="true"/>

  <copyField source="tm_*" dest="_text_"/>
  <copyField source="ss_*" dest="_text_"/>

  <fieldType name="string" class="solr.StrField" sortMissingLast="true" docValues="true"/>
  <fieldType name="boolean" class="solr.BoolField" sortMissingLast="true"/>
  <fieldType name="pint" class="solr.IntPointField" docValues="true"/>
  <fieldType name="plong" class="solr.LongPointField" docValues="true"/>
  <fieldType name="pfloat" class="solr.FloatPointField" docValues="true"/>
  <fieldType name="pdate" class="solr.DatePointField" docValues="true"/>

  <fieldType name="text_en" class="solr.TextField" positionIncrementGap="100">
    <analyzer type="index">
      <tokenizer class="solr.StandardTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.EnglishPossessiveFilterFactory"/>
      <filter class="solr.StopFilterFactory" ignoreCase="true" words="stopwords.txt"/>
      <filter class="solr.PorterStemFilterFactory"/>
    </analyzer>
    <analyzer type="query">
      <tokenizer class="solr.StandardTokenizerFactory"/>
      <filter class="solr.LowerCaseFilterFactory"/>
      <filter class="solr.EnglishPossessiveFilterFactory"/>
      <filter class="solr.StopFilterFactory" ignoreCase="true" words="stopwords.txt"/>
      <filter class="solr.PorterStemFilterFactory"/>
    </analyzer>
  </fieldType>

</schema>
